{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "env": {
        "EAS_BUILD_GRADLE_PROPERTIES": "android.suppressUnsupportedCompileSdk=36"
      }
    }
  },
  "submit": {
    "production": {}
  }
}